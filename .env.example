# Django
DJANGO_SECRET_KEY=dev-secret-change-me
DEBUG=True
ALLOWED_HOSTS=*

# Database (set DB_ENGINE=postgres to use PostgreSQL)
DB_ENGINE=sqlite
DB_NAME=finflow
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Kafka
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC_CREATED=transaction.created
KAFKA_TOPIC_UPDATED=transaction.updated
KAFKA_GROUP_ID=processing-service

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=finflow-docs

# HMAC (internal service auth)
HMAC_SECRET=dev-hmac-secret-change-me

# Processing Service
ACCOUNT_SERVICE_URL=http://localhost:8000
